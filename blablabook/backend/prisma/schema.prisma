generator client {
  provider      = "prisma-client"
  output        = "../generated/prisma"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  // nécessaire à la version 6
  url      = env("DATABASE_URL")
}

model book {
  id            String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  isbn          String        @db.VarChar(20) @unique
  openLibraryId String?        @unique @db.VarChar(100)
  title         String         @db.VarChar(255)
  author        String?        @db.VarChar(255)
  genre         String?        @db.VarChar(100)
  description   String?
  thumbnail     String?        @db.VarChar(512)
  publisher     String?        @db.VarChar(512)
  pageCount     Int?
  language      String?        @db.VarChar(10)
  publishedYear Int?
  library_item  library_item[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
// Ne pose pas de problème majeur, si on veut faire des migrations automatiques (npx prisma migrate dev) il faudra ajouter manuellement les contraintes CHECK dans les migrations SQL générées.
model library_item {
  id        String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String        @db.Uuid
  bookId    String        @db.Uuid
  status    ReadingStatus @default(TO_READ)
  rating    Int?
  review    String?
  createdAt DateTime?     @default(now()) @db.Timestamptz(6)
  updatedAt DateTime?     @default(now()) @db.Timestamptz(6)
  book      book          @relation(fields: [bookId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_book")
  user      user          @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user")

  @@unique([userId, bookId], map: "unique_user_book")
}

model user {
  id           String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email        String         @unique @db.VarChar(255)
  password     String         @db.VarChar(255)
  username     String         @db.VarChar(100)
  createdAt    DateTime?      @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime?      @default(now()) @db.Timestamptz(6)
  library_item library_item[]
  refresh_tokens refresh_token[]
}

model refresh_token {
  id Int @id @default(autoincrement())

  token String @unique

  userId String @db.Uuid

  user    user @relation(fields: [userId], references: [id], onDelete: Cascade)

  issuedAt  DateTime @default(now())
  expiresAt DateTime

  @@map("refresh_token")
}

enum ReadingStatus {
  TO_READ
  READING
  READ
}
