# URL du backend — utilisée par le proxy Next.js (rewrites dans next.config.ts)
# et par les Server Components (SSR).
# ⚠️  Obligatoire si le backend tourne sur un port autre que 3000.
# En prod, cette valeur est l'URL Render du backend.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Utilisée uniquement par les Server Components (page.tsx, search/page.tsx, book/[id]/page.tsx).
# Doit pointer directement vers le backend (pas de proxy).
API_URL=http://localhost:3001

# url du site en ligne nécessaire pour l'optimisation du seo 
NEXT_PUBLIC_SITE_URL=https://blablabook-front.onrender.com